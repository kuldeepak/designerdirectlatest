{% schema %}
{
  "name": "Metaobject Data",
  "target": "section"
}
{% endschema %} 

{% if customer.tags contains 'approved' %}
  {% assign approved_brands = shop.metaobjects.brand_configurator.values | where: "contact_email", customer.email %}
  {{ contact_email }}hjjj
  {{ customer.email }}
  {% if approved_brands.size > 0 %}
    <table border="1" cellpadding="8" cellspacing="0">
      <thead>
        <tr>
          <th>Brand Name</th>
          <th>Bio</th>
          <th>Category</th>
          <th>Phone</th>
          <th>Email</th>
          <th>Lookbook File</th>
          <th>Linesheet PDF</th>
          <th>Edit</th>
        </tr>
      </thead>
      <tbody>
        {% for brand in approved_brands %}
          <tr>
            <td>{{ brand.brand_name }}</td>
            <td>{{ brand.bio }}</td>
            <td>{{ brand.category }}</td>
            <td>{{ brand.phone }}</td>
            <td>{{ brand.contact_email }}</td>
            <td>
              {% if brand.lookbook_file %}
                <a href="{{ brand.lookbook_file.value.url }}" target="_blank">Open Lookbook</a>
              {% endif %}
            </td>
            <td>
              {% if brand.linesheet_pdf %}
                <a href="{{ brand.linesheet_pdf.value.url }}" target="_blank">Open Linesheet</a>
              {% endif %}
            </td>
            <td>
              <button onclick="editBrand('{{ brand.system.id }}')">Edit</button>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% else %}
    <p>No brands assigned to your account.</p>
  {% endif %}
{% endif %}
{% comment %}end designer form {% endcomment %}

<div id="editModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.6); z-index:9999;">
  <div style="background:#fff; max-width:500px; margin:5% auto; padding:20px; position:relative;">
    
    <h3>Edit Brand</h3>

    <form id="editBrandForm">
      <input type="hidden" name="id" id="edit_id">
   <div class="fieldset_et ">
  <div class="form-control_et">
      <input type="text" name="brand_name" id="edit_brand_name" placeholder="Brand Name" required>
      </div>
      <div class="form-control_et grid_frome">
      <input type="text" name="bio" id="edit_bio" placeholder="Bio">
      <input type="text" name="category" id="edit_category" placeholder="Category">
      </div>
       <div class="form-control_et grid_frome">
      <input type="text" name="phone" id="edit_phone" placeholder="Phone">
      <input type="email" name="contact_email" id="edit_email" placeholder="Email" readonly>
       </div>
        <div class="form-control_et">
      <input type="file" name="lookbook_file" accept=".pdf,.jpg,.png" >
        </div>
         <div class="form-control_et">
      <input type="file" name="linesheet_pdf" accept=".pdf" >
         </div></div>

<button type="submit" id="updateBtn">
  <span id="btnText">Update</span>
  <span id="btnSpinner" style="display:none; margin-left:8px;">⏳</span>
</button>

     <button type="button" onclick="closeEdit()">Cancel</button>
    </form>

    <p id="edit_error" style="color:red; display:none;"></p>
    <p id="edit_success" style="color:green; display:none;">Updated successfully</p>
  </div>
</div>
{% comment %}end edit metaobject form     {% endcomment %}

{% comment %} start Spinner code  {% endcomment %}
<style>
#btnSpinner {
  display: inline-block;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
</style>
<script>
document.getElementById("editBrandForm").addEventListener("submit", async function(e){
  e.preventDefault();

  const btn = document.getElementById("updateBtn");
  const btnText = document.getElementById("btnText");
  const spinner = document.getElementById("btnSpinner");

  // 🔄 spinner ON
  btn.disabled = true;
  btnText.style.display = "none";
  spinner.style.display = "inline-block";

  const formData = new FormData(this);

  try {
    const res = await fetch("/apps/configurator", {
      method: "PUT",
      body: formData
    });

    const result = await res.json();

    if(result.success){
      document.getElementById("edit_success").style.display = "block";

      // ✅ hard refresh
      setTimeout(() => {
        window.location.reload(true);
      }, 500);

    } else {
      throw new Error(result.error || "Update failed");
    }

  } catch (err) {
    document.getElementById("edit_error").innerText = err.message;
    document.getElementById("edit_error").style.display = "block";

    // ❌ spinner OFF (agar error aaye)
    btn.disabled = false;
    btnText.style.display = "inline";
    spinner.style.display = "none";
  }
});
</script>


{% comment %} end Spinner code  {% endcomment %}

<script>
  const brandsData = {
    {% for brand in approved_brands %}
      "{{ brand.system.id }}": {
        brand_name: "{{ brand.brand_name | escape }}",
        bio: "{{ brand.bio | escape }}",
        category: "{{ brand.category | escape }}",
        phone: "{{ brand.phone | escape }}",
        contact_email: "{{ brand.contact_email | escape }}"
      },
    {% endfor %}
  };

  function editBrand(id) {
    const brand = brandsData[id];
       alert(brand);
    if (!brand) return;

    document.getElementById("edit_id").value = id;
    document.getElementById("edit_brand_name").value = brand.brand_name;
    document.getElementById("edit_bio").value = brand.bio;
    document.getElementById("edit_category").value = brand.category;
    document.getElementById("edit_phone").value = brand.phone;
    document.getElementById("edit_email").value = brand.contact_email;
    

    document.getElementById("editModal").style.display = "block";
  }

  function closeEdit() {
    document.getElementById("editModal").style.display = "none";
  }
</script>

<script>
  document.getElementById("editBrandForm").addEventListener("submit", async function(e){
    e.preventDefault();

    const formData = new FormData(this);

    const res = await fetch("/apps/configurator", {
      method: "PUT",
      body: formData
    });

    const result = await res.json();

    if(result.success){
      document.getElementById("edit_success").style.display = "block";
      {% comment %} setTimeout(() => location.reload(), 1000); {% endcomment %}
    } else {
      document.getElementById("edit_error").innerText = result.error;
      document.getElementById("edit_error").style.display = "block";
    }
  });
</script>